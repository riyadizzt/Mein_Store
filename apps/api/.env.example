# =============================================================
# MALAK STORE — API BACKEND ENVIRONMENT (example)
# Copy to apps/api/.env and fill in your own values.
# NEVER commit the real .env file — it contains secrets.
# =============================================================

# ─── DATABASE (Supabase EU) ────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── REDIS (Upstash EU) ────────────────────────────────────
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_HOST:6379
UPSTASH_REDIS_REST_URL=https://YOUR_PROJECT.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ─── JWT AUTH ──────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=generate-a-random-64-character-string
JWT_REFRESH_SECRET=generate-another-random-64-character-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SHOPIFY POS ───────────────────────────────────────────
SHOPIFY_STORE_URL=https://your-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret
SHOPIFY_API_VERSION=2024-07

# ─── META (Facebook + Instagram Shop + Catalog) ───────────
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
META_ACCESS_TOKEN=your-access-token
META_CATALOG_ID=your-catalog-id
META_PIXEL_ID=your-pixel-id

# ─── TIKTOK SHOP ───────────────────────────────────────────
TIKTOK_APP_ID=your-app-id
TIKTOK_APP_SECRET=your-app-secret
TIKTOK_APP_KEY=your-app-key
TIKTOK_SHOP_CIPHER=your-shop-cipher

# ─── STRIPE ────────────────────────────────────────────────
# Use sk_test_... for development, sk_live_... only in production
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── KLARNA ────────────────────────────────────────────────
KLARNA_API_URL=https://api.playground.klarna.com
KLARNA_USERNAME=your-username
KLARNA_PASSWORD=your-password
KLARNA_WEBHOOK_SECRET=your-webhook-secret

# ─── PAYPAL ────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your-client-id
PAYPAL_CLIENT_SECRET=your-client-secret
PAYPAL_MODE=sandbox

# ─── SUMUP ─────────────────────────────────────────────────
SUMUP_API_KEY=your-sumup-api-key
SUMUP_MERCHANT_CODE=your-merchant-code

# ─── DHL ───────────────────────────────────────────────────
DHL_API_KEY=your-api-key
DHL_API_SECRET=your-api-secret
DHL_EKP=your-ekp-number
DHL_GKP_USER=your-gkp-user
DHL_GKP_PASS=your-gkp-password
DHL_SANDBOX=true
DHL_WEBHOOK_SECRET=your-webhook-secret

# ─── DPD ───────────────────────────────────────────────────
DPD_USER_ID=your-user-id
DPD_PASSWORD=your-password

# ─── EMAIL (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
EMAIL_FROM_NOREPLY=noreply@your-domain.com
EMAIL_FROM_ORDERS=orders@your-domain.com
EMAIL_FROM_SUPPORT=support@your-domain.com
EMAIL_DISPLAY_NAME=Malak Bekleidung
EMAIL_WORKER_ENABLED=true
EMAIL_SEND_DIRECT=false

# ─── CONTACT FORM ──────────────────────────────────────────
# Where contact-form admin notifications are sent
CONTACT_ADMIN_EMAIL=info@your-domain.com

# ─── COMPANY DATA (for invoices / legal pages) ────────────
COMPANY_NAME=Malak Bekleidung
COMPANY_ADDRESS=Your Street 1, 12345 City
COMPANY_VAT_ID=DE123456789
COMPANY_CEO=Your Name
COMPANY_REGISTER=HRB 12345
COMPANY_PHONE=+49 30 1234567
COMPANY_SHIP_STREET=Warehouse Street
COMPANY_SHIP_HOUSE=1
COMPANY_SHIP_PLZ=12345
COMPANY_SHIP_CITY=City
COMPANY_CONTACT_EMAIL=info@your-domain.com
COMPANY_LOGO_URL=https://your-domain.com/logo.png

# ─── APP URLs ──────────────────────────────────────────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
API_PORT=3001

# ─── OAUTH ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
APPLE_CLIENT_ID=com.your-domain.web
APPLE_TEAM_ID=your-team-id
APPLE_KEY_ID=your-key-id
APPLE_PRIVATE_KEY_PATH=./apple-private-key.p8

# ─── TRANSLATION (DeepL) ───────────────────────────────────
DEEPL_API_KEY=your-deepl-key
DEEPL_API_URL=https://api-free.deepl.com

# ─── IMAGE CDN (ImageKit) ──────────────────────────────────
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
IMAGEKIT_PUBLIC_KEY=public_your_key
IMAGEKIT_PRIVATE_KEY=private_your_key

# ─── AI (Anthropic + Gemini) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
GEMINI_API_KEY=your-gemini-key

# ─── WHATSAPP BUSINESS API ─────────────────────────────────
WHATSAPP_TOKEN=your-meta-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# ─── SENTRY ────────────────────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_ORG=your-org
SENTRY_PROJECT=omnichannel-store

# ─── BUSINESS LOGIC ────────────────────────────────────────
RESERVATION_TIMEOUT_MINUTES=30
SHIPPING_PROVIDER=dhl
