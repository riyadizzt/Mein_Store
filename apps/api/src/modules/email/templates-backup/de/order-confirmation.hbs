<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding:0 0 24px;"><div style="width:64px;height:64px;border-radius:50%;background-color:#dcfce7;display:inline-block;text-align:center;line-height:64px;"><span style="font-size:32px;color:#16a34a;">&#10003;</span></div></td></tr>
</table>
<h1 style="margin:0 0 8px;font-size:26px;color:#1a1a2e;text-align:center;font-weight:700;">Danke für deine Bestellung!</h1>
<p style="text-align:center;color:#6b7280;margin:0 0 24px;">Hallo {{firstName}}, wir haben deine Bestellung erhalten.</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 32px;"><tr><td align="center"><span style="display:inline-block;padding:10px 24px;background-color:#f8f7f4;border-radius:12px;font-family:monospace;font-size:16px;font-weight:700;color:#1a1a2e;letter-spacing:1px;">{{orderNumber}}</span><p style="margin:8px 0 0;color:#9ca3af;font-size:12px;">{{orderDate}}</p></td></tr></table>

<p style="font-weight:600;font-size:14px;margin:0 0 12px;color:#1a1a2e;">Deine Artikel:</p>
{{#each items}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 8px;background:#f8f7f4;border-radius:12px;">
  <tr><td style="padding:12px 16px;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
      <td style="vertical-align:middle;"><p style="margin:0 0 2px;font-weight:600;font-size:14px;color:#1a1a2e;">{{name}}</p><p style="margin:0;font-size:12px;color:#6b7280;">{{sku}}{{#if color}} · {{color}}{{/if}}{{#if size}} · {{size}}{{/if}} · {{quantity}}x</p></td>
      <td style="text-align:right;vertical-align:middle;"><span style="font-weight:700;font-size:15px;color:#1a1a2e;">&euro;{{totalPrice}}</span></td>
    </tr></table>
  </td></tr>
</table>
{{/each}}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:20px 0;border-top:2px solid #f3f4f6;padding-top:12px;">
  <tr><td style="padding:3px 0;font-size:14px;color:#6b7280;">Zwischensumme</td><td style="padding:3px 0;font-size:14px;text-align:right;">&euro;{{subtotal}}</td></tr>
  <tr><td style="padding:3px 0;font-size:14px;color:#6b7280;">Versand</td><td style="padding:3px 0;font-size:14px;text-align:right;">&euro;{{shippingCost}}</td></tr>
  <tr><td style="padding:10px 0 2px;font-size:18px;font-weight:700;color:#1a1a2e;border-top:2px solid #1a1a2e;">Gesamt</td><td style="padding:10px 0 2px;font-size:18px;font-weight:700;text-align:right;color:#1a1a2e;border-top:2px solid #1a1a2e;">&euro;{{total}}</td></tr>
  <tr><td colspan="2" style="font-size:11px;color:#9ca3af;">inkl. 19% MwSt.</td></tr>
</table>

{{#if shippingAddress}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:20px 0;background:#f8f7f4;border-radius:12px;">
  <tr><td style="padding:14px 18px;"><p style="margin:0 0 4px;font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Lieferadresse</p><p style="margin:0;font-size:14px;color:#1a1a2e;">{{shippingAddress.firstName}} {{shippingAddress.lastName}}<br>{{shippingAddress.street}} {{shippingAddress.houseNumber}}<br>{{shippingAddress.postalCode}} {{shippingAddress.city}}</p></td></tr>
</table>
{{/if}}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;"><tr><td align="center"><a href="{{appUrl}}/de/tracking?mode=order&orderNumber={{orderNumber}}" style="display:inline-block;background-color:#1a1a2e;color:#ffffff;font-weight:600;font-size:15px;padding:14px 40px;border-radius:12px;text-decoration:none;">Bestellung verfolgen</a></td></tr></table>
<p style="color:#9ca3af;font-size:12px;text-align:center;">Du hast ein 14-tägiges Widerrufsrecht ab Erhalt der Ware.</p>
