{{!-- Daily Summary Email — English --}}
<h1 style="margin:0 0 8px;font-size:24px;color:#1a1a2e;text-align:center;font-weight:700;">📊 Daily Report</h1>
<p style="text-align:center;color:#6b7280;margin:0 0 32px;font-size:14px;">{{dateStr}}</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
  <tr>
    <td width="50%" style="padding:8px;">
      <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;padding:16px;text-align:center;">
        <div style="font-size:11px;color:#16a34a;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Orders</div>
        <div style="font-size:28px;font-weight:800;color:#15803d;margin:4px 0;">{{orderCount}}</div>
      </div>
    </td>
    <td width="50%" style="padding:8px;">
      <div style="background:#fefce8;border:1px solid #fde68a;border-radius:12px;padding:16px;text-align:center;">
        <div style="font-size:11px;color:#ca8a04;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Revenue</div>
        <div style="font-size:28px;font-weight:800;color:#a16207;margin:4px 0;">&euro;{{revenue}}</div>
      </div>
    </td>
  </tr>
</table>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
  <tr><td style="padding:12px 16px;background:#f9fafb;border-radius:10px;border:1px solid #f0f0f0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td style="padding:8px 0;border-bottom:1px solid #f0eeea;">
          <span style="font-size:13px;color:#6b7280;">Same day last week</span>
        </td>
        <td style="padding:8px 0;border-bottom:1px solid #f0eeea;text-align:right;font-weight:700;font-size:13px;color:#1a1a2e;">
          {{lastWeekCount}} orders (&euro;{{lastWeekRevenue}})
        </td>
      </tr>
      <tr>
        <td style="padding:8px 0;border-bottom:1px solid #f0eeea;">
          <span style="font-size:13px;color:#6b7280;">New customers</span>
        </td>
        <td style="padding:8px 0;border-bottom:1px solid #f0eeea;text-align:right;font-weight:700;font-size:13px;color:#1a1a2e;">
          {{newCustomers}}
        </td>
      </tr>
      <tr>
        <td style="padding:8px 0;border-bottom:1px solid #f0eeea;">
          <span style="font-size:13px;color:#6b7280;">Products below reorder point</span>
        </td>
        <td style="padding:8px 0;border-bottom:1px solid #f0eeea;text-align:right;font-weight:700;font-size:13px;color:{{#if lowStockAlert}}#dc2626{{else}}#1a1a2e{{/if}};">
          {{lowStock}}
        </td>
      </tr>
      <tr>
        <td style="padding:8px 0;">
          <span style="font-size:13px;color:#6b7280;">Open returns</span>
        </td>
        <td style="padding:8px 0;text-align:right;font-weight:700;font-size:13px;color:#1a1a2e;">
          {{openReturns}}
        </td>
      </tr>
    </table>
  </td></tr>
</table>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding:8px 0;">
    <a href="{{{dashboardUrl}}}" style="display:inline-block;background:#d4a853;color:#ffffff;font-weight:600;font-size:14px;padding:12px 40px;border-radius:8px;text-decoration:none;">Open Dashboard</a>
  </td></tr>
</table>
