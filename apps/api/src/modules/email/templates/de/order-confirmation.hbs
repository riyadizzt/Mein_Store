<!-- Success Icon -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding:0 0 20px;">
    <div style="width:72px;height:72px;border-radius:50%;background:#ecfdf5;display:inline-block;text-align:center;line-height:72px;">
      <span style="font-size:36px;color:#16a34a;">&#10003;</span>
    </div>
  </td></tr>
</table>

<h1 style="margin:0 0 8px;font-size:28px;color:#1a1a2e;text-align:center;font-weight:700;font-family:Georgia,'Times New Roman',serif;">Danke für deine Bestellung!</h1>
<p style="text-align:center;color:#6b7280;margin:0 0 28px;font-size:15px;">Hallo <strong style="color:#1a1a2e;">{{firstName}}</strong>, wir haben deine Bestellung erhalten und bereiten sie vor.</p>

<!-- Order Number Badge -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
  <tr><td align="center">
    <div style="display:inline-block;padding:12px 28px;background:#f5eed9;border:1px solid #dcc68a;border-radius:12px;">
      <span style="font-family:'Courier New',monospace;font-size:18px;font-weight:700;color:#1a1a2e;letter-spacing:1px;">{{orderNumber}}</span>
    </div>
    <p style="margin:8px 0 0;color:#9ca3af;font-size:12px;">{{orderDate}}</p>
  </td></tr>
</table>

<!-- Progress Bar -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 36px;">
  <tr><td>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td width="25%" align="center"><div style="width:32px;height:32px;border-radius:50%;background:#d4a853;display:inline-block;text-align:center;line-height:32px;"><span style="color:#fff;font-size:14px;font-weight:700;">&#10003;</span></div><div style="font-size:10px;color:#d4a853;font-weight:600;margin-top:6px;">Bestellt</div></td>
        <td width="25%" align="center"><div style="width:32px;height:32px;border-radius:50%;background:#e5e7eb;display:inline-block;text-align:center;line-height:32px;"><span style="color:#9ca3af;font-size:12px;">2</span></div><div style="font-size:10px;color:#9ca3af;margin-top:6px;">Vorbereitung</div></td>
        <td width="25%" align="center"><div style="width:32px;height:32px;border-radius:50%;background:#e5e7eb;display:inline-block;text-align:center;line-height:32px;"><span style="color:#9ca3af;font-size:12px;">3</span></div><div style="font-size:10px;color:#9ca3af;margin-top:6px;">Versendet</div></td>
        <td width="25%" align="center"><div style="width:32px;height:32px;border-radius:50%;background:#e5e7eb;display:inline-block;text-align:center;line-height:32px;"><span style="color:#9ca3af;font-size:12px;">4</span></div><div style="font-size:10px;color:#9ca3af;margin-top:6px;">Zugestellt</div></td>
      </tr>
    </table>
  </td></tr>
</table>

<!-- Items -->
<p style="font-weight:700;font-size:13px;margin:0 0 12px;color:#1a1a2e;text-transform:uppercase;letter-spacing:1px;">Deine Artikel</p>
{{#each items}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 8px;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr>
    <td style="padding:14px 16px;vertical-align:middle;">
      <p style="margin:0 0 3px;font-weight:600;font-size:14px;color:#1a1a2e;">{{name}}</p>
      <p style="margin:0;font-size:12px;color:#6b7280;">{{sku}}{{#if color}} &middot; {{color}}{{/if}}{{#if size}} &middot; {{size}}{{/if}} &middot; {{quantity}}&times;</p>
    </td>
    <td style="padding:14px 16px;text-align:right;vertical-align:middle;white-space:nowrap;">
      <span style="font-weight:700;font-size:16px;color:#1a1a2e;">&euro;{{totalPrice}}</span>
    </td>
  </tr>
</table>
{{/each}}

<!-- Price Summary -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0 0;">
  <tr><td colspan="2" style="height:1px;background:#e5e7eb;"></td></tr>
  <tr>
    <td style="padding:10px 0 4px;font-size:14px;color:#6b7280;">Zwischensumme</td>
    <td style="padding:10px 0 4px;font-size:14px;text-align:right;color:#6b7280;">&euro;{{subtotal}}</td>
  </tr>
  <tr>
    <td style="padding:4px 0;font-size:14px;color:#6b7280;">Versand</td>
    <td style="padding:4px 0;font-size:14px;text-align:right;color:#6b7280;">{{#if shippingCost}}&euro;{{shippingCost}}{{else}}Kostenlos{{/if}}</td>
  </tr>
  <tr><td colspan="2" style="height:2px;background:#1a1a2e;margin:8px 0;"></td></tr>
  <tr>
    <td style="padding:12px 0 4px;font-size:20px;font-weight:700;color:#1a1a2e;">Gesamt</td>
    <td style="padding:12px 0 4px;font-size:20px;font-weight:700;text-align:right;color:#1a1a2e;">&euro;{{total}}</td>
  </tr>
  <tr><td colspan="2" style="font-size:11px;color:#9ca3af;">inkl. 19% MwSt.</td></tr>
</table>

<!-- Shipping Address -->
{{#if shippingAddress}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:28px 0 0;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr><td style="padding:16px 20px;">
    <p style="margin:0 0 6px;font-size:11px;color:#6b7280;font-weight:700;text-transform:uppercase;letter-spacing:1px;">Lieferadresse</p>
    <p style="margin:0;font-size:14px;color:#1a1a2e;line-height:1.6;">
      {{shippingAddress.firstName}} {{shippingAddress.lastName}}<br>
      {{shippingAddress.street}} {{shippingAddress.houseNumber}}<br>
      {{shippingAddress.postalCode}} {{shippingAddress.city}}
    </p>
  </td></tr>
</table>
{{/if}}

<!-- CTA Button -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:32px 0 16px;">
  <tr><td align="center">
    <a href="{{appUrl}}/de/tracking?mode=order&orderNumber={{orderNumber}}" style="display:inline-block;background:#d4a853;color:#ffffff;font-weight:600;font-size:15px;padding:14px 48px;border-radius:8px;text-decoration:none;min-height:48px;line-height:20px;">Bestellung verfolgen</a>
  </td></tr>
</table>

<p style="color:#9ca3af;font-size:12px;text-align:center;margin:0;">Du hast ein 14-t&auml;giges Widerrufsrecht ab Erhalt der Ware.</p>
