<!-- Return Status Icon -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding:0 0 20px;">
    <div style="width:72px;height:72px;border-radius:50%;background:{{#if (eq status 'approved')}}#f0fdf4{{else if (eq status 'rejected')}}#fef2f2{{else if (eq status 'received')}}#eff6ff{{else if (eq status 'refunded')}}#faf5ff{{else}}#faf9f7{{/if}};display:inline-block;text-align:center;line-height:72px;">
      <span style="font-size:36px;color:{{#if (eq status 'approved')}}#16a34a{{else if (eq status 'rejected')}}#dc2626{{else if (eq status 'received')}}#2563eb{{else if (eq status 'refunded')}}#7c3aed{{else}}#d4a853{{/if}};">{{#if (eq status 'approved')}}&#10003;{{else if (eq status 'rejected')}}&#10007;{{else if (eq status 'received')}}&#9993;{{else if (eq status 'refunded')}}&#8364;{{else}}&#8617;{{/if}}</span>
    </div>
  </td></tr>
</table>

<!-- Title -->
<h1 style="margin:0 0 8px;font-size:28px;color:#1a1a2e;text-align:center;font-weight:700;font-family:Georgia,'Times New Roman',serif;">
  {{#if (eq status 'approved')}}R&uuml;cksendung genehmigt{{else if (eq status 'rejected')}}R&uuml;cksendung abgelehnt{{else if (eq status 'received')}}R&uuml;cksendung eingetroffen{{else if (eq status 'refunded')}}Erstattung verarbeitet{{else}}R&uuml;cksendung best&auml;tigt{{/if}}
</h1>

<!-- Greeting -->
<p style="text-align:center;color:#6b7280;margin:0 0 28px;font-size:15px;">
  Hallo <strong style="color:#1a1a2e;">{{firstName}}</strong>,
  {{#if returnNumber}}Retoure <strong>{{returnNumber}}</strong> f&uuml;r {{/if}}Bestellung <strong>{{orderNumber}}</strong>
</p>

{{#if (eq status 'approved')}}
<!-- APPROVED: Return Address + Instructions -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#f0fdf4;border-radius:12px;border:1px solid #bbf7d0;">
  <tr><td style="padding:20px;">
    <p style="margin:0 0 12px;font-size:13px;font-weight:700;color:#16a34a;text-transform:uppercase;letter-spacing:1px;">N&auml;chste Schritte</p>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr><td style="padding:8px 0;border-bottom:1px solid #dcfce7;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
          <td width="32" style="vertical-align:top;"><div style="width:24px;height:24px;border-radius:50%;background:#d4a853;text-align:center;line-height:24px;color:#fff;font-size:12px;font-weight:700;">1</div></td>
          <td style="vertical-align:top;padding-left:10px;"><p style="margin:0;font-size:14px;color:#1a1a2e;">Ware mit dem R&uuml;cksendeetikett verpacken</p></td>
        </tr></table>
      </td></tr>
      <tr><td style="padding:8px 0;border-bottom:1px solid #dcfce7;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
          <td width="32" style="vertical-align:top;"><div style="width:24px;height:24px;border-radius:50%;background:#d4a853;text-align:center;line-height:24px;color:#fff;font-size:12px;font-weight:700;">2</div></td>
          <td style="vertical-align:top;padding-left:10px;"><p style="margin:0;font-size:14px;color:#1a1a2e;">Bei DHL oder einem Paketshop abgeben</p></td>
        </tr></table>
      </td></tr>
      <tr><td style="padding:8px 0;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
          <td width="32" style="vertical-align:top;"><div style="width:24px;height:24px;border-radius:50%;background:#d4a853;text-align:center;line-height:24px;color:#fff;font-size:12px;font-weight:700;">3</div></td>
          <td style="vertical-align:top;padding-left:10px;"><p style="margin:0;font-size:14px;color:#1a1a2e;">Erstattung nach Pr&uuml;fung innerhalb von 5&ndash;10 Werktagen</p></td>
        </tr></table>
      </td></tr>
    </table>
  </td></tr>
</table>

{{#if returnAddress}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr><td style="padding:20px;">
    <p style="margin:0 0 8px;font-size:13px;font-weight:700;color:#1a1a2e;text-transform:uppercase;letter-spacing:1px;">R&uuml;cksendeadresse</p>
    <p style="margin:0;font-size:14px;color:#374151;line-height:1.6;white-space:pre-line;">{{returnAddress}}</p>
  </td></tr>
</table>
{{/if}}

<p style="font-size:14px;color:#6b7280;line-height:1.6;margin:0 0 20px;">Bitte sende die Ware innerhalb von <strong style="color:#1a1a2e;">14 Tagen</strong> zur&uuml;ck. Die R&uuml;cksendung ist f&uuml;r dich <strong>kostenlos</strong>.</p>

{{else if (eq status 'rejected')}}
<!-- REJECTED: Reason -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#fef2f2;border-radius:12px;border:1px solid #fecaca;">
  <tr><td style="padding:20px;">
    <p style="margin:0 0 8px;font-size:13px;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:1px;">Begr&uuml;ndung</p>
    <p style="margin:0;font-size:14px;color:#374151;line-height:1.6;">{{#if rejectionReason}}{{rejectionReason}}{{else}}Leider konnten wir deine R&uuml;cksendung nicht akzeptieren.{{/if}}</p>
  </td></tr>
</table>

<p style="font-size:14px;color:#6b7280;line-height:1.6;margin:0 0 20px;">Falls du Fragen hast, kontaktiere bitte unseren Kundenservice.</p>

{{else if (eq status 'received')}}
<!-- RECEIVED: Inspection in progress -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#eff6ff;border-radius:12px;border:1px solid #bfdbfe;">
  <tr><td style="padding:20px;">
    <p style="margin:0 0 8px;font-size:13px;font-weight:700;color:#2563eb;text-transform:uppercase;letter-spacing:1px;">Status-Update</p>
    <p style="margin:0;font-size:14px;color:#374151;line-height:1.6;">Dein Paket ist bei uns eingetroffen und wird jetzt gepr&uuml;ft. Du erh&auml;ltst eine weitere E-Mail sobald die Pr&uuml;fung abgeschlossen ist.</p>
  </td></tr>
</table>

<p style="font-size:14px;color:#6b7280;line-height:1.6;margin:0 0 20px;">Die Pr&uuml;fung dauert in der Regel <strong style="color:#1a1a2e;">1&ndash;3 Werktage</strong>.</p>

{{else if (eq status 'refunded')}}
<!-- REFUNDED: Amount + Confirmation -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#faf5ff;border-radius:12px;border:1px solid #e9d5ff;">
  <tr><td style="padding:20px;text-align:center;">
    <p style="margin:0 0 4px;font-size:13px;font-weight:700;color:#7c3aed;text-transform:uppercase;letter-spacing:1px;">Erstattungsbetrag</p>
    {{#if refundAmount}}<p style="margin:0;font-size:32px;font-weight:800;color:#1a1a2e;">&euro;{{refundAmount}}</p>{{/if}}
    <p style="margin:8px 0 0;font-size:13px;color:#6b7280;">wird auf deine urspr&uuml;ngliche Zahlungsmethode erstattet</p>
  </td></tr>
</table>

<p style="font-size:14px;color:#6b7280;line-height:1.6;margin:0 0 20px;">Die Gutschrift erscheint je nach Zahlungsanbieter innerhalb von <strong style="color:#1a1a2e;">3&ndash;10 Werktagen</strong> auf deinem Konto.</p>

{{else}}
<!-- GENERIC: fallback -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr><td style="padding:20px;">
    <p style="margin:0;font-size:14px;color:#374151;line-height:1.6;">{{message}}</p>
  </td></tr>
</table>
{{/if}}

<p style="color:#9ca3af;font-size:12px;text-align:center;margin:0;">Fragen? <a href="{{appUrl}}/de/contact" style="color:#d4a853;text-decoration:none;">Kundenservice kontaktieren</a></p>
