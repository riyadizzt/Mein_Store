<!-- Status Icon -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding:0 0 20px;">
    <div style="width:72px;height:72px;border-radius:50%;background:{{#if isDelivered}}#ecfdf5{{else if isShipped}}#eff6ff{{else}}#f5eed9{{/if}};display:inline-block;text-align:center;line-height:72px;">
      <span style="font-size:36px;color:{{#if isDelivered}}#16a34a{{else if isShipped}}#2563eb{{else}}#d4a853{{/if}};">{{#if isShipped}}&#9992;{{else if isDelivered}}&#10003;{{else}}&#128230;{{/if}}</span>
    </div>
  </td></tr>
</table>

<h1 style="margin:0 0 8px;font-size:28px;color:#1a1a2e;text-align:center;font-weight:700;font-family:Georgia,'Times New Roman',serif;">Status-Update</h1>
<p style="text-align:center;color:#6b7280;margin:0 0 16px;font-size:15px;">Hallo <strong style="color:#1a1a2e;">{{firstName}}</strong>, deine Bestellung wurde aktualisiert.</p>

<!-- Order Number + Status Badge -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;">
  <tr><td align="center">
    <div style="display:inline-block;padding:12px 28px;background:#f5eed9;border:1px solid #dcc68a;border-radius:12px;margin-bottom:12px;">
      <span style="font-family:'Courier New',monospace;font-size:16px;font-weight:700;color:#1a1a2e;">{{orderNumber}}</span>
    </div><br>
    <span style="display:inline-block;padding:8px 24px;background:{{#if isDelivered}}#ecfdf5{{else if isShipped}}#eff6ff{{else}}#fef3c7{{/if}};border:1px solid {{#if isDelivered}}#86efac{{else if isShipped}}#93c5fd{{else}}#fcd34d{{/if}};border-radius:50px;font-size:14px;font-weight:700;color:{{#if isDelivered}}#16a34a{{else if isShipped}}#2563eb{{else}}#b45309{{/if}};">{{statusLabel}}</span>
  </td></tr>
</table>

<!-- Progress Bar -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
  <tr><td>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td width="25%" align="center"><div style="width:32px;height:32px;border-radius:50%;background:#16a34a;display:inline-block;text-align:center;line-height:32px;"><span style="color:#fff;font-size:14px;">&#10003;</span></div><div style="font-size:10px;color:#16a34a;font-weight:600;margin-top:6px;">Bestellt</div></td>
        <td width="25%" align="center"><div style="width:32px;height:32px;border-radius:50%;background:{{#if isShipped}}#d4a853{{else if isDelivered}}#16a34a{{else}}#e5e7eb{{/if}};display:inline-block;text-align:center;line-height:32px;"><span style="color:{{#if isShipped}}#fff{{else if isDelivered}}#fff{{else}}#9ca3af{{/if}};font-size:12px;">{{#if isShipped}}&#9992;{{else if isDelivered}}&#10003;{{else}}2{{/if}}</span></div><div style="font-size:10px;color:{{#if isShipped}}#d4a853{{else if isDelivered}}#16a34a{{else}}#9ca3af{{/if}};font-weight:600;margin-top:6px;">Versendet</div></td>
        <td width="25%" align="center"><div style="width:32px;height:32px;border-radius:50%;background:{{#if isDelivered}}#d4a853{{else}}#e5e7eb{{/if}};display:inline-block;text-align:center;line-height:32px;"><span style="color:{{#if isDelivered}}#fff{{else}}#9ca3af{{/if}};font-size:12px;">{{#if isDelivered}}&#10003;{{else}}3{{/if}}</span></div><div style="font-size:10px;color:{{#if isDelivered}}#d4a853{{else}}#9ca3af{{/if}};font-weight:600;margin-top:6px;">Zugestellt</div></td>
      </tr>
    </table>
  </td></tr>
</table>

{{#if trackingNumber}}
<!-- Tracking Box -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr><td style="padding:20px;text-align:center;">
    <div style="font-size:11px;color:#6b7280;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">Sendungsnummer</div>
    <div style="font-size:20px;font-weight:700;font-family:'Courier New',monospace;color:#1a1a2e;letter-spacing:1px;margin-bottom:16px;">{{trackingNumber}}</div>
    {{#if trackingUrl}}<a href="{{{trackingUrl}}}" style="display:inline-block;background:#d4a853;color:#ffffff;font-weight:600;font-size:14px;padding:12px 36px;border-radius:8px;text-decoration:none;">Sendung verfolgen</a>{{/if}}
  </td></tr>
</table>
{{/if}}

{{#if items}}
<p style="font-weight:700;font-size:13px;margin:0 0 12px;color:#1a1a2e;text-transform:uppercase;letter-spacing:1px;">Deine Artikel</p>
{{#each items}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 8px;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr>
    <td style="padding:12px 16px;vertical-align:middle;"><p style="margin:0 0 2px;font-weight:600;font-size:14px;color:#1a1a2e;">{{name}}</p><p style="margin:0;font-size:12px;color:#6b7280;">{{#if color}}{{color}}{{/if}}{{#if size}} &middot; {{size}}{{/if}} &middot; {{quantity}}&times;</p></td>
    <td style="padding:12px 16px;text-align:right;vertical-align:middle;white-space:nowrap;"><span style="font-weight:700;font-size:15px;color:#1a1a2e;">&euro;{{totalPrice}}</span></td>
  </tr>
</table>
{{/each}}
{{/if}}

{{#if shippingAddress}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:20px 0;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr><td style="padding:14px 18px;"><p style="margin:0 0 6px;font-size:11px;color:#6b7280;font-weight:700;text-transform:uppercase;letter-spacing:1px;">Lieferadresse</p><p style="margin:0;font-size:14px;color:#1a1a2e;line-height:1.6;">{{shippingAddress.firstName}} {{shippingAddress.lastName}}<br>{{shippingAddress.street}} {{shippingAddress.houseNumber}}<br>{{shippingAddress.postalCode}} {{shippingAddress.city}}</p></td></tr>
</table>
{{/if}}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0 16px;"><tr><td align="center">
  <a href="{{appUrl}}/de/tracking?mode=order&orderNumber={{orderNumber}}" style="display:inline-block;background:#1a1a2e;color:#ffffff;font-weight:600;font-size:15px;padding:14px 48px;border-radius:8px;text-decoration:none;">Bestellung verfolgen</a>
</td></tr></table>

{{#if returnEligible}}
<!-- Return CTA — only on delivered state, public token-link (no login needed) -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:16px 0 8px;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr><td style="padding:20px;text-align:center;">
    <p style="margin:0 0 6px;font-size:11px;color:#6b7280;font-weight:700;text-transform:uppercase;letter-spacing:1px;">Rueckgabe</p>
    <p style="margin:0 0 14px;font-size:13px;color:#1a1a2e;">Du hast 14 Tage Zeit, deine Bestellung zu widerrufen.</p>
    <a href="{{{returnUrl}}}" style="display:inline-block;background:#ffffff;color:#1a1a2e;font-weight:600;font-size:14px;padding:12px 32px;border-radius:8px;text-decoration:none;border:1.5px solid #1a1a2e;">Retoure anfordern</a>
  </td></tr>
</table>
{{/if}}

<p style="color:#9ca3af;font-size:12px;text-align:center;margin:0;">Fragen? <a href="{{appUrl}}/de/contact" style="color:#d4a853;text-decoration:none;">Kundenservice kontaktieren</a></p>
