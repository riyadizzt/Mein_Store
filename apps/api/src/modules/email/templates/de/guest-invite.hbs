    <a href="{{appUrl}}/de/auth/create-account?token={{inviteToken}}&email={{email}}" style="display:inline-block;background:#d4a853;color:#ffffff;font-weight:600;font-size:15px;padding:14px 48px;border-radius:8px;text-decoration:none;">Konto erstellen</a>
  </td></tr>
