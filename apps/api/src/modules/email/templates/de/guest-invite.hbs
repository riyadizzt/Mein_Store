<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr><td style="padding:20px;">
    <p style="margin:0 0 14px;font-weight:700;font-size:14px;color:#1a1a2e;text-align:center;">Erstelle ein Konto und profitiere von:</p>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr><td style="padding:6px 0;font-size:14px;color:#2d2d2d;"><span style="color:#d4a853;margin-right:8px;">&#10003;</span> Schnellerer Checkout</td></tr>
