<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="color-scheme" content="light">
<title>{{subject}}</title>
<!--[if mso]><style>table,td{font-family:Arial,Helvetica,sans-serif !important;}</style><![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#f5f3ef;font-family:'Cairo','Noto Sans Arabic','Segoe UI',Roboto,Arial,sans-serif;-webkit-font-smoothing:antialiased;direction:rtl;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f3ef;" dir="rtl">
<tr><td align="center" style="padding:40px 16px;">

<!-- Main Card -->
<table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,0.06);" dir="rtl">

<!-- ═══ HEADER ═══ -->
<tr><td style="background:#1a1a2e;padding:32px 40px 24px;text-align:center;">
  {{#if logoUrl}}
    <img src="{{logoUrl}}" alt="{{companyName}}" width="140" style="max-width:140px;height:auto;display:block;margin:0 auto;">
  {{else}}
    <div style="margin:0 auto 8px;width:48px;height:48px;border-radius:50%;border:2px solid #d4a853;text-align:center;line-height:48px;">
      <span style="color:#d4a853;font-size:22px;font-weight:700;font-family:Georgia,'Times New Roman',serif;">M</span>
    </div>
    <div style="font-size:13px;font-weight:700;color:#ffffff;letter-spacing:4px;text-transform:uppercase;">MALAK BEKLEIDUNG</div>
  {{/if}}
  <div style="height:1px;background:linear-gradient(to right,transparent,#d4a853,transparent);margin-top:20px;"></div>
</td></tr>

<!-- ═══ CONTENT ═══ -->
<tr><td style="padding:40px 36px 32px;color:#2d2d2d;font-size:15px;line-height:1.9;text-align:right;direction:rtl;">
  {{{content}}}
</td></tr>

<!-- ═══ FOOTER ═══ -->
<tr><td style="background:#1a1a2e;padding:32px 36px;">

  <!-- Social Icons -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding-bottom:20px;">
    <a href="https://instagram.com/malak.bekleidung" style="display:inline-block;width:36px;height:36px;border-radius:50%;background:#3d3250;border:1px solid #4a4060;text-align:center;line-height:36px;margin:0 6px;text-decoration:none;">
      <img src="https://img.icons8.com/ios-glyphs/16/d4a853/instagram-new.png" alt="Instagram" width="16" height="16" style="vertical-align:middle;">
    </a>
    <a href="https://facebook.com/malak.bekleidung" style="display:inline-block;width:36px;height:36px;border-radius:50%;background:#3d3250;border:1px solid #4a4060;text-align:center;line-height:36px;margin:0 6px;text-decoration:none;">
      <img src="https://img.icons8.com/ios-glyphs/16/d4a853/facebook-new.png" alt="Facebook" width="16" height="16" style="vertical-align:middle;">
    </a>
    <a href="https://tiktok.com/@malak.bekleidung" style="display:inline-block;width:36px;height:36px;border-radius:50%;background:#3d3250;border:1px solid #4a4060;text-align:center;line-height:36px;margin:0 6px;text-decoration:none;">
      <img src="https://img.icons8.com/ios-glyphs/16/d4a853/tiktok.png" alt="TikTok" width="16" height="16" style="vertical-align:middle;">
    </a>
  </td></tr>
  </table>

  <!-- Payment Icons -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding-bottom:20px;">
    <span style="display:inline-block;padding:4px 10px;border:1px solid #333348;border-radius:4px;margin:2px 3px;font-size:10px;color:#d4a853;font-weight:700;letter-spacing:0.5px;">VISA</span>
    <span style="display:inline-block;padding:4px 10px;border:1px solid #333348;border-radius:4px;margin:2px 3px;font-size:10px;color:#d4a853;font-weight:700;letter-spacing:0.5px;">MASTERCARD</span>
    <span style="display:inline-block;padding:4px 10px;border:1px solid #333348;border-radius:4px;margin:2px 3px;font-size:10px;color:#d4a853;font-weight:700;letter-spacing:0.5px;">KLARNA</span>
    <span style="display:inline-block;padding:4px 10px;border:1px solid #333348;border-radius:4px;margin:2px 3px;font-size:10px;color:#d4a853;font-weight:700;letter-spacing:0.5px;">PAYPAL</span>
  </td></tr>
  </table>

  <!-- Company Info -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="color:#8888a0;font-size:11px;line-height:1.6;">
    <div style="font-weight:600;color:#ccccdd;margin-bottom:4px;">{{companyName}}</div>
    {{#if companyAddress}}<div>{{companyAddress}}</div>{{/if}}
    {{#if companyVatId}}<div>الرقم الضريبي: {{companyVatId}}</div>{{/if}}
    <div>{{companyEmail}}</div>
    <div style="height:1px;background:#2a2a40;margin:16px 0;"></div>
    <div style="color:#555570;font-size:10px;">&copy; {{currentYear}} {{companyName}} &middot; <a href="{{shopUrl}}/ar/legal/impressum" style="color:#666680;text-decoration:none;">البيانات القانونية</a> &middot; <a href="{{shopUrl}}/ar/legal/datenschutz" style="color:#666680;text-decoration:none;">الخصوصية</a> &middot; <a href="{{shopUrl}}/ar/legal/agb" style="color:#666680;text-decoration:none;">الشروط والأحكام</a></div>
  </td></tr>
  </table>

</td></tr>

</table>
<!-- End Main Card -->

</td></tr>
</table>
</body>
</html>
