<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="color-scheme" content="light">
<title>{{subject}}</title>
<!--[if mso]><style>table,td{font-family:Arial,Helvetica,sans-serif !important;}</style><![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#f5f3ef;font-family:'Cairo','Noto Sans Arabic','Segoe UI',Roboto,Arial,sans-serif;-webkit-font-smoothing:antialiased;direction:rtl;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f3ef;" dir="rtl">
<tr><td align="center" style="padding:40px 16px;">

<!-- Main Card -->
<table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,0.06);" dir="rtl">

<!-- ═══ HEADER ═══ -->
<tr><td style="padding:28px 40px;text-align:center;border-bottom:1px solid #f0f0f0;">
  <div style="font-size:14px;font-weight:700;color:#0f1419;letter-spacing:5px;text-transform:uppercase;font-family:Georgia,'Times New Roman',serif;" dir="ltr">MALAK BEKLEIDUNG</div>
</td></tr>

<!-- ═══ CONTENT ═══ -->
<tr><td style="padding:40px 36px 32px;color:#2d2d2d;font-size:15px;line-height:1.9;text-align:right;direction:rtl;">
  {{{content}}}
</td></tr>

<!-- ═══ FOOTER ═══ -->
<tr><td style="background:#000000;padding:32px 36px;">

  <!-- Social Icons -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding-bottom:20px;">
    <a href="https://instagram.com/malak.bekleidung" style="display:inline-block;width:40px;height:40px;border-radius:50%;background:#1a1a1a;border:1px solid #333;text-align:center;line-height:40px;margin:0 5px;text-decoration:none;">
      <img src="https://img.icons8.com/ios-filled/18/ffffff/instagram-new.png" alt="Instagram" width="18" height="18" style="vertical-align:middle;">
    </a>
    <a href="https://facebook.com/malak.bekleidung" style="display:inline-block;width:40px;height:40px;border-radius:50%;background:#1a1a1a;border:1px solid #333;text-align:center;line-height:40px;margin:0 5px;text-decoration:none;">
      <img src="https://img.icons8.com/ios-filled/18/ffffff/facebook-new.png" alt="Facebook" width="18" height="18" style="vertical-align:middle;">
    </a>
    <a href="https://tiktok.com/@malak.bekleidung" style="display:inline-block;width:40px;height:40px;border-radius:50%;background:#1a1a1a;border:1px solid #333;text-align:center;line-height:40px;margin:0 5px;text-decoration:none;">
      <img src="https://img.icons8.com/ios-filled/18/ffffff/tiktok.png" alt="TikTok" width="18" height="18" style="vertical-align:middle;">
    </a>
  </td></tr>
  </table>

  <!-- Payment Icons -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding-bottom:20px;">
    <img src="https://img.icons8.com/color/32/visa.png" alt="Visa" width="32" height="32" style="margin:0 4px;vertical-align:middle;">
    <img src="https://img.icons8.com/color/32/mastercard-logo.png" alt="Mastercard" width="32" height="32" style="margin:0 4px;vertical-align:middle;">
    <img src="https://img.icons8.com/color/32/paypal.png" alt="PayPal" width="32" height="32" style="margin:0 4px;vertical-align:middle;">
    <span style="display:inline-block;padding:4px 8px;border:1px solid #333;border-radius:4px;margin:0 4px;font-size:10px;color:#ffb8c6;font-weight:700;vertical-align:middle;">Klarna</span>
    <span style="display:inline-block;padding:4px 8px;border:1px solid #333;border-radius:4px;margin:0 4px;font-size:10px;color:#1ccc78;font-weight:700;vertical-align:middle;">SumUp</span>
    <img src="https://img.icons8.com/ios-filled/32/d4a853/apple-pay.png" alt="Apple Pay" width="32" height="32" style="margin:0 4px;vertical-align:middle;">
    <img src="https://img.icons8.com/color/32/google-pay.png" alt="Google Pay" width="32" height="32" style="margin:0 4px;vertical-align:middle;">
  </td></tr>
  </table>

  <!-- Company Info -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="color:#777;font-size:11px;line-height:1.6;">
    <div style="font-weight:600;color:#ccc;margin-bottom:4px;">{{companyName}}</div>
    {{#if companyAddress}}<div>{{companyAddress}}</div>{{/if}}
    {{#if companyVatId}}<div>الرقم الضريبي: {{companyVatId}}</div>{{/if}}
    <div>{{companyEmail}}</div>
    <div style="height:1px;background:#222;margin:16px 0;"></div>
    <div style="color:#555;font-size:10px;">&copy; {{currentYear}} {{companyName}} &middot; <a href="{{shopUrl}}/ar/legal/impressum" style="color:#666;text-decoration:none;">البيانات القانونية</a> &middot; <a href="{{shopUrl}}/ar/legal/datenschutz" style="color:#666;text-decoration:none;">الخصوصية</a> &middot; <a href="{{shopUrl}}/ar/legal/agb" style="color:#666;text-decoration:none;">الشروط والأحكام</a></div>
  </td></tr>
  </table>

</td></tr>

</table>
<!-- End Main Card -->

</td></tr>
</table>
</body>
</html>
