<!-- Return Status Icon -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding:0 0 20px;">
    <div style="width:72px;height:72px;border-radius:50%;background:{{#if (eq status 'approved')}}#f0fdf4{{else if (eq status 'rejected')}}#fef2f2{{else if (eq status 'received')}}#eff6ff{{else if (eq status 'refunded')}}#faf5ff{{else}}#faf9f7{{/if}};display:inline-block;text-align:center;line-height:72px;">
      <span style="font-size:36px;color:{{#if (eq status 'approved')}}#16a34a{{else if (eq status 'rejected')}}#dc2626{{else if (eq status 'received')}}#2563eb{{else if (eq status 'refunded')}}#7c3aed{{else}}#d4a853{{/if}};">{{#if (eq status 'approved')}}&#10003;{{else if (eq status 'rejected')}}&#10007;{{else if (eq status 'received')}}&#9993;{{else if (eq status 'refunded')}}&#8364;{{else}}&#8617;{{/if}}</span>
    </div>
  </td></tr>
</table>

<!-- Title -->
<h1 style="margin:0 0 8px;font-size:28px;color:#1a1a2e;text-align:center;font-weight:700;font-family:'Noto Sans Arabic',Georgia,serif;">
  {{#if (eq status 'approved')}}تمت الموافقة على الإرجاع{{else if (eq status 'rejected')}}تم رفض الإرجاع{{else if (eq status 'received')}}تم استلام المرتجع{{else if (eq status 'refunded')}}تمت معالجة الاسترداد{{else}}تأكيد الإرجاع{{/if}}
</h1>

<!-- Greeting -->
<p style="text-align:center;color:#6b7280;margin:0 0 28px;font-size:15px;line-height:1.9;">
  مرحباً <strong style="color:#1a1a2e;">{{firstName}}</strong>،
  {{#if returnNumber}}إرجاع <strong>{{returnNumber}}</strong> لـ{{/if}}طلب <strong>{{orderNumber}}</strong>
</p>

{{#if (eq status 'approved')}}
<!-- APPROVED -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#f0fdf4;border-radius:12px;border:1px solid #bbf7d0;">
  <tr><td style="padding:20px;">
    <p style="margin:0 0 12px;font-size:13px;font-weight:700;color:#16a34a;text-align:right;letter-spacing:1px;">الخطوات التالية</p>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr><td style="padding:8px 0;border-bottom:1px solid #dcfce7;">
        <table role="presentation" width="100%"><tr>
          <td style="vertical-align:top;text-align:right;padding-right:10px;"><p style="margin:0;font-size:14px;color:#1a1a2e;line-height:1.9;">تغليف المنتج مع ملصق الإرجاع</p></td>
          <td width="32" style="vertical-align:top;"><div style="width:24px;height:24px;border-radius:50%;background:#d4a853;text-align:center;line-height:24px;color:#fff;font-size:12px;font-weight:700;">1</div></td>
        </tr></table>
      </td></tr>
      <tr><td style="padding:8px 0;border-bottom:1px solid #dcfce7;">
        <table role="presentation" width="100%"><tr>
          <td style="vertical-align:top;text-align:right;padding-right:10px;"><p style="margin:0;font-size:14px;color:#1a1a2e;line-height:1.9;">تسليمه لشركة DHL أو نقطة تسليم</p></td>
          <td width="32" style="vertical-align:top;"><div style="width:24px;height:24px;border-radius:50%;background:#d4a853;text-align:center;line-height:24px;color:#fff;font-size:12px;font-weight:700;">2</div></td>
        </tr></table>
      </td></tr>
      <tr><td style="padding:8px 0;">
        <table role="presentation" width="100%"><tr>
          <td style="vertical-align:top;text-align:right;padding-right:10px;"><p style="margin:0;font-size:14px;color:#1a1a2e;line-height:1.9;">استرداد المبلغ خلال 5–10 أيام عمل</p></td>
          <td width="32" style="vertical-align:top;"><div style="width:24px;height:24px;border-radius:50%;background:#d4a853;text-align:center;line-height:24px;color:#fff;font-size:12px;font-weight:700;">3</div></td>
        </tr></table>
      </td></tr>
    </table>
  </td></tr>
</table>

{{#if returnAddress}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr><td style="padding:20px;">
    <p style="margin:0 0 8px;font-size:13px;font-weight:700;color:#1a1a2e;text-align:right;letter-spacing:1px;">عنوان الإرجاع</p>
    <p style="margin:0;font-size:14px;color:#374151;line-height:1.6;white-space:pre-line;text-align:right;" dir="ltr">{{returnAddress}}</p>
  </td></tr>
</table>
{{/if}}

<p style="font-size:14px;color:#6b7280;line-height:1.9;margin:0 0 20px;text-align:right;">يرجى إرسال المنتج خلال <strong style="color:#1a1a2e;">14 يوماً</strong>.{{#if sendLabel}} الإرجاع <strong>مجاني</strong>.{{else}} <strong>تكاليف الشحن على عاتق العميل.</strong>{{/if}}</p>

{{else if (eq status 'rejected')}}
<!-- REJECTED -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#fef2f2;border-radius:12px;border:1px solid #fecaca;">
  <tr><td style="padding:20px;">
    <p style="margin:0 0 8px;font-size:13px;font-weight:700;color:#dc2626;text-align:right;letter-spacing:1px;">السبب</p>
    <p style="margin:0;font-size:14px;color:#374151;line-height:1.9;text-align:right;">{{#if rejectionReason}}{{rejectionReason}}{{else}}للأسف لم نتمكن من قبول طلب الإرجاع.{{/if}}</p>
  </td></tr>
</table>

<p style="font-size:14px;color:#6b7280;line-height:1.9;margin:0 0 20px;text-align:right;">إذا كان لديك أي استفسارات، يرجى التواصل مع خدمة العملاء.</p>

{{else if (eq status 'received')}}
<!-- RECEIVED -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#eff6ff;border-radius:12px;border:1px solid #bfdbfe;">
  <tr><td style="padding:20px;">
    <p style="margin:0 0 8px;font-size:13px;font-weight:700;color:#2563eb;text-align:right;letter-spacing:1px;">تحديث الحالة</p>
    <p style="margin:0;font-size:14px;color:#374151;line-height:1.9;text-align:right;">تم استلام طردك وجاري فحصه الآن. ستتلقى بريداً إلكترونياً آخر عند اكتمال الفحص.</p>
  </td></tr>
</table>

<p style="font-size:14px;color:#6b7280;line-height:1.9;margin:0 0 20px;text-align:right;">يستغرق الفحص عادةً <strong style="color:#1a1a2e;">1–3 أيام عمل</strong>.</p>

{{else if (eq status 'refunded')}}
<!-- REFUNDED -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#faf5ff;border-radius:12px;border:1px solid #e9d5ff;">
  <tr><td style="padding:20px;text-align:center;">
    <p style="margin:0 0 4px;font-size:13px;font-weight:700;color:#7c3aed;text-transform:uppercase;letter-spacing:1px;">مبلغ الاسترداد</p>
    {{#if refundAmount}}<p style="margin:0;font-size:32px;font-weight:800;color:#1a1a2e;">&euro;{{refundAmount}}</p>{{/if}}
    <p style="margin:8px 0 0;font-size:13px;color:#6b7280;">سيتم إعادته إلى وسيلة الدفع الأصلية</p>
  </td></tr>
</table>

<p style="font-size:14px;color:#6b7280;line-height:1.9;margin:0 0 20px;text-align:right;">سيظهر المبلغ في حسابك خلال <strong style="color:#1a1a2e;">3–10 أيام عمل</strong> حسب مزود الدفع.</p>

{{else}}
<!-- GENERIC -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px;background:#faf9f7;border-radius:12px;border:1px solid #f0eeea;">
  <tr><td style="padding:20px;">
    <p style="margin:0;font-size:14px;color:#374151;line-height:1.9;text-align:right;">{{message}}</p>
  </td></tr>
</table>
{{/if}}

<p style="color:#9ca3af;font-size:12px;text-align:center;margin:0;">للاستفسارات <a href="{{appUrl}}/ar/contact" style="color:#d4a853;text-decoration:none;">تواصل معنا</a></p>
