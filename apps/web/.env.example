# =============================================================
# MALAK STORE — WEB FRONTEND ENVIRONMENT (example)
# Copy to apps/web/.env.local and fill in your own values.
# NEVER commit the real .env.local file — it is gitignored.
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# =============================================================

# ─── API & APP URLs ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── STRIPE (publishable key only — never the secret) ─────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ─── GOOGLE PLACES (address autocomplete) ─────────────────
# Optional — leave empty to use Photon (free, OSM-based) fallback
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ─── IMAGEKIT CDN ─────────────────────────────────────────
NEXT_PUBLIC_IMAGEKIT_URL=https://ik.imagekit.io/your_id
