{
  "name": "omnichannel-store",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "pnpm lint:finance-contract && turbo lint",
    "lint:finance-contract": "bash scripts/lint-finance-contract.sh",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "turbo": "^2.9.1",
    "typescript": "^5.6.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "pnpm": {
    "overrides": {
      "@smithy/types": "4.13.1"
    }
  }
}
