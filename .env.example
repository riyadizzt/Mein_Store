# =============================================================
# OMNICHANNEL STORE — Environment Variables
# Kopiere diese Datei zu .env.local und fülle alle Werte aus
# NIEMALS .env.local in Git committen!
# =============================================================

# ─── DATABASE ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres


# ─── REDIS (Upstash EU) ────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@HOST:PORT
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ─── JWT AUTH ──────────────────────────────────────────────
JWT_SECRET=min-64-zeichen-zufaelliger-string
JWT_REFRESH_SECRET=anderer-min-64-zeichen-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SHOPIFY POS ───────────────────────────────────────────
SHOPIFY_STORE_URL=https://dein-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxx
SHOPIFY_WEBHOOK_SECRET=xxxx
SHOPIFY_API_VERSION=2024-07

# ─── META (Facebook + Instagram) ──────────────────────────
META_APP_ID=xxxx
META_APP_SECRET=xxxx
META_ACCESS_TOKEN=xxxx
META_CATALOG_ID=xxxx
META_PIXEL_ID=xxxx

# ─── TIKTOK SHOP ───────────────────────────────────────────
TIKTOK_APP_ID=xxxx
TIKTOK_APP_SECRET=xxxx
TIKTOK_APP_KEY=xxxx
TIKTOK_SHOP_CIPHER=xxxx

# ─── STRIPE ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ─── KLARNA ────────────────────────────────────────────────
KLARNA_API_URL=https://api.klarna.com
KLARNA_USERNAME=xxxx
KLARNA_PASSWORD=xxxx

# ─── PAYPAL ────────────────────────────────────────────────
PAYPAL_CLIENT_ID=xxxx
PAYPAL_CLIENT_SECRET=xxxx
PAYPAL_MODE=live

# ─── DHL ───────────────────────────────────────────────────
DHL_API_KEY=xxxx
DHL_API_SECRET=xxxx
DHL_ACCOUNT_NUMBER=xxxx
DHL_SANDBOX=false

# ─── DPD ───────────────────────────────────────────────────
DPD_USER_ID=xxxx
DPD_PASSWORD=xxxx

# ─── EMAIL (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@dein-shop.de
EMAIL_FROM_NAME=Malak Bekleidung

# ─── CLOUDINARY (EU) ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ─── SENTRY ────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@sentry.io/xxxx
SENTRY_ORG=xxxx
SENTRY_PROJECT=omnichannel-store

# ─── APP URLs ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://dein-shop.de
NEXT_PUBLIC_API_URL=https://api.dein-shop.de
API_PORT=3001

# ─── OAUTH ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx
APPLE_CLIENT_ID=com.dein-shop.web
APPLE_TEAM_ID=xxxx
APPLE_KEY_ID=xxxx
APPLE_PRIVATE_KEY_PATH=./apple-private-key.p8
