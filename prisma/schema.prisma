enum SizeChartType {
  tops        // Brust, Taille, Länge
  bottoms     // Taille, Hüfte, Innenbeinlänge
  dresses     // Brust, Taille, Hüfte, Länge
  shoes       // Fußlänge
  kids        // Körpergröße
  accessories // Einheitsgröße
}

model SizeChart {
  id            String        @id @default(uuid())
  name          String        // z.B. "Özdemir Textil — Damenkleider"
  supplierId    String?       @map("supplier_id")
  categoryId    String?       @map("category_id")
  chartType     SizeChartType @default(tops) @map("chart_type")
  fitNote       String?       @map("fit_note")     // "Fällt klein aus", "Normal geschnitten"
  fitNoteAr     String?       @map("fit_note_ar")
  fitNoteEn     String?       @map("fit_note_en")
  isDefault     Boolean       @default(false) @map("is_default")  // Default for category if no supplier match
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  entries       SizeChartEntry[]
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  category      Category?     @relation(fields: [categoryId], references: [id])

  @@index([supplierId])
  @@index([categoryId])
  @@index([chartType, isDefault])
  @@map("size_charts")
}

model SizeChartEntry {
  id            String    @id @default(uuid())
  sizeChartId   String    @map("size_chart_id")
  size          String    // S, M, L, XL, 38, 39, 40, 110, 116...
  sortOrder     Int       @default(0) @map("sort_order")
  // Measurements in cm
  bust          Decimal?  @db.Decimal(5, 1)  // Brust
  waist         Decimal?  @db.Decimal(5, 1)  // Taille
  hip           Decimal?  @db.Decimal(5, 1)  // Hüfte
  length        Decimal?  @db.Decimal(5, 1)  // Gesamtlänge
  inseam        Decimal?  @db.Decimal(5, 1)  // Innenbeinlänge
  shoulder      Decimal?  @db.Decimal(5, 1)  // Schulterbreite
  sleeve        Decimal?  @db.Decimal(5, 1)  // Ärmellänge
  footLength    Decimal?  @map("foot_length") @db.Decimal(5, 1)  // Fußlänge
  bodyHeight    Decimal?  @map("body_height") @db.Decimal(5, 1)  // Körpergröße (Kinder)
  euSize        String?   @map("eu_size")     // EU-Größe Mapping (z.B. "38")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  sizeChart     SizeChart @relation(fields: [sizeChartId], references: [id], onDelete: Cascade)

  // Prevents two entries with the same size label (e.g. two "M" rows) in
  // the same chart. The recommendation engine in sizing.service picks the
  // "best match" by Σ|delta|; duplicate sizes made the tie-break non-
  // deterministic. Pre-flight verified against Live-DB: 0 existing dupes.
  @@unique([sizeChartId, size])
  @@index([sizeChartId, sortOrder])
  @@map("size_chart_entries")
}

model CustomerMeasurement {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  heightCm      Decimal?  @map("height_cm") @db.Decimal(5, 1)
