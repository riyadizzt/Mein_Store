  // Last provider error message when processRefund failed at the Stripe/
  // PayPal/etc. layer. When set, the return stays at `status=inspected`
  // so the admin UI can surface a "Retry refund" button with context.
  // Cleared to null on the next successful refund attempt.
  refundError           String?      @map("refund_error")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  order    Order     @relation(fields: [orderId], references: [id])
  shipment Shipment? @relation(fields: [shipmentId], references: [id])

  @@index([orderId])
  @@index([returnNumber])
  @@map("returns")
