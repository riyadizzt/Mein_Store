enum CouponType {
  percentage
  fixed_amount
  free_shipping
}

enum PromotionType {
  seasonal
  quantity_discount
  flash_sale
}

model Coupon {
  id                 String     @id @default(uuid())
  code               String     @unique
  type               CouponType @default(percentage)
  description        String?
  discountPercent    Decimal?   @map("discount_percent") @db.Decimal(5, 2)
  discountAmount     Decimal?   @map("discount_amount") @db.Decimal(10, 2)
  freeShipping       Boolean    @default(false) @map("free_shipping")
  minOrderAmount     Decimal?   @map("min_order_amount") @db.Decimal(10, 2)
  maxUsageCount      Int?       @map("max_usage_count")
  usedCount          Int        @default(0) @map("used_count")
  onePerCustomer     Boolean    @default(false) @map("one_per_customer")
  isActive           Boolean    @default(true) @map("is_active")
  startAt            DateTime?  @map("start_at")
  expiresAt          DateTime?  @map("expires_at")
  appliesToCategoryId String?   @map("applies_to_category_id")
  appliesToProductId  String?   @map("applies_to_product_id")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  appliesToCategory  Category?  @relation(fields: [appliesToCategoryId], references: [id])
  appliesToProduct   Product?   @relation(fields: [appliesToProductId], references: [id])
