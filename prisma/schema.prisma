// ─────────────────────────────────────────────────────────────
// PROMOTIONS
// ─────────────────────────────────────────────────────────────

enum CouponType {
  percentage
  fixed_amount
  free_shipping
}

enum PromotionType {
  seasonal
  quantity_discount
  flash_sale
}

model Coupon {
  id                 String     @id @default(uuid())
  code               String     @unique
  type               CouponType @default(percentage)
  description        String?
  discountPercent    Decimal?   @map("discount_percent") @db.Decimal(5, 2)
  discountAmount     Decimal?   @map("discount_amount") @db.Decimal(10, 2)
  freeShipping       Boolean    @default(false) @map("free_shipping")
  minOrderAmount     Decimal?   @map("min_order_amount") @db.Decimal(10, 2)
  maxUsageCount      Int?       @map("max_usage_count")
  usedCount          Int        @default(0) @map("used_count")
  onePerCustomer     Boolean    @default(false) @map("one_per_customer")
  isActive           Boolean    @default(true) @map("is_active")
  startAt            DateTime?  @map("start_at")
  expiresAt          DateTime?  @map("expires_at")
  appliesToCategoryId String?   @map("applies_to_category_id")
  appliesToProductId  String?   @map("applies_to_product_id")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  appliesToCategory  Category?  @relation(fields: [appliesToCategoryId], references: [id])
  appliesToProduct   Product?   @relation(fields: [appliesToProductId], references: [id])
  usages             CouponUsage[]

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String   @map("coupon_id")
  orderId   String   @map("order_id")
  userId    String?  @map("user_id")
  email     String?
  createdAt DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@unique([couponId, orderId])
  @@index([couponId, userId])
  @@index([couponId, email])
  @@map("coupon_usages")
}

model Promotion {
  id              String        @id @default(uuid())
  name            String
  type            PromotionType
  description     String?
  discountPercent Decimal?      @map("discount_percent") @db.Decimal(5, 2)
  discountAmount  Decimal?      @map("discount_amount") @db.Decimal(10, 2)
  minQuantity     Int?          @map("min_quantity")
  categoryId      String?       @map("category_id")
  productId       String?       @map("product_id")
  isActive        Boolean       @default(true) @map("is_active")
  startAt         DateTime      @map("start_at")
  endAt           DateTime      @map("end_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  category Category? @relation(fields: [categoryId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])

  @@index([isActive, startAt, endAt])
  @@map("promotions")
}

