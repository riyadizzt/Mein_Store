// ─────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String?   @map("password_hash")
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  phone                String?
  preferredLang        Language  @default(de) @map("preferred_lang")
  role                 UserRole  @default(customer)
  shopifyId            String?   @unique @map("shopify_id")
  isVerified           Boolean   @default(false) @map("is_verified")
  isActive             Boolean   @default(true) @map("is_active")
  twoFactorSecret      String?   @map("two_factor_secret")
  twoFactorEnabled     Boolean   @default(false) @map("two_factor_enabled")
  loginAttempts        Int       @default(0) @map("login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  profileImageUrl      String?   @map("profile_image_url")
  lastLoginAt          DateTime? @map("last_login_at")
  isBlocked            Boolean   @default(false) @map("is_blocked")
  blockedAt            DateTime? @map("blocked_at")
  blockReason          String?   @map("block_reason")
  blockedBy            String?   @map("blocked_by")
  tags                 Json      @default("[]") // ["VIP", "Stammkunde", "Problem"]
  recoveryEmail        String?   @map("recovery_email")  // Emergency-only, DB-editable only
  emailVerifyToken     String?   @map("email_verify_token")
  emailVerifyExpires   DateTime? @map("email_verify_expires")
  staffRole            StaffRole? @map("staff_role")
  permissions          Json?      @default("[]")  // ["orders.view","orders.edit",...]
  inviteToken          String?    @unique @map("invite_token")
  inviteExpiresAt      DateTime?  @map("invite_expires_at")
  invitedBy            String?    @map("invited_by")
  scheduledDeletionAt  DateTime? @map("scheduled_deletion_at")
  anonymizedAt         DateTime? @map("anonymized_at")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  addresses           Address[]
  orders              Order[]
  reviews             ProductReview[]
  wishlistItems       WishlistItem[]
  loyaltyAccount      LoyaltyAccount?
  gdprConsents        GdprConsent[]
  oauthAccounts       OauthAccount[]
  refreshTokens       RefreshToken[]
  passwordResets      PasswordReset[]
  moderatedReviews    ProductReview[]    @relation("ModeratedReviews")
  dataExportRequests  DataExportRequest[]
  emailChangeRequests EmailChangeRequest[]
  phoneChangeRequests PhoneChangeRequest[]
  customerNotes       CustomerNote[]
  activities          CustomerActivity[]
  abandonedCarts      AbandonedCart[]
  notifications       Notification[]  @relation("UserNotifications")
  measurements        CustomerMeasurement?

  @@map("users")
}

model OauthAccount {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  provider     String   // google | apple
  providerAccountId String @map("provider_account_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  isRevoked   Boolean   @default(false) @map("is_revoked")
  deviceName  String?   @map("device_name")
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRevoked])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model EmailChangeRequest {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  newEmail  String    @map("new_email")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_change_requests")
}

model PhoneChangeRequest {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  newPhone  String    @map("new_phone")
  codeHash  String    @map("code_hash") // SMS verification code hash
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("phone_change_requests")
}

model Address {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  label             String?   // "Zuhause", "Büro"
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  company           String?
  street            String
  houseNumber       String    @map("house_number")
  addressLine2      String?   @map("address_line2")
  city              String
  state             String?
  postalCode        String    @map("postal_code")
  country           String    @default("DE")
  isDefaultShipping Boolean   @default(false) @map("is_default_shipping")
  isDefaultBilling  Boolean   @default(false) @map("is_default_billing")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId, deletedAt])
  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  parentId    String?   @map("parent_id")
  slug        String    @unique
  imageUrl    String?   @map("image_url")
  iconKey     String?   @map("icon_key") // canonical icon key from CategoryIcon set; null → slug-based fallback
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  // Google Product Taxonomy ID (e.g. "1604" = "Apparel & Accessories > Clothing > Shirts & Tops").
  // Required by Google Shopping Merchant Center; without it, listings are rejected or downgraded.
  // Populated via searchable dropdown in /admin/categories (C6). Null = fallback to Malak category
  // name in the Google feed (with an audit-log warning).
  googleCategoryId    String? @map("google_category_id")
  googleCategoryLabel String? @map("google_category_label") // cached human-readable label for UI
  // eBay Category-Tree leaf ID (e.g. "11483" = "Damen > Jeans"). Required per
  // eBay Offer create/publish call (C11). Distinct from Google's taxonomy —
  // eBay has its own category tree, unrelated to Google's. Null = listing
  // push will fail with sync_error "missing_ebay_category_id" forcing admin
  // to fill this field via the category editor. Admin pflegt einmalig pro
  // Kategorie; eBay-IDs sind stabil über Jahre.
  ebayCategoryId      String? @map("ebay_category_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  parent       Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryHierarchy")
  translations CategoryTranslation[]
  products     Product[]
  coupons      Coupon[]
  promotions   Promotion[]
  sizeCharts   SizeChart[]

  @@map("categories")
}

model CategoryTranslation {
  id          String   @id @default(uuid())
  categoryId  String   @map("category_id")
  language    Language
  name        String
  description String?

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, language])
  @@map("category_translations")
}

model Product {
  id          String   @id @default(uuid())
  shopifyId   String?  @unique @map("shopify_id")
  slug        String   @unique
  categoryId  String   @map("category_id")
  brand       String?
  gender      Gender?
  basePrice   Decimal  @map("base_price") @db.Decimal(10, 2)
  salePrice   Decimal? @map("sale_price") @db.Decimal(10, 2)
  taxRate     Decimal  @default(19.00) @map("tax_rate") @db.Decimal(5, 2)
  isActive    Boolean  @default(true) @map("is_active")
  isFeatured  Boolean  @default(false) @map("is_featured")
  excludeFromReturns Boolean @default(false) @map("exclude_from_returns")
  returnExclusionReason String? @map("return_exclusion_reason") // hygiene, custom_made, sealed
  // C7 / FA-05 — default flipped from true → false. New products are
  // opt-IN to channel publishing; admin must explicitly toggle each
  // channel. Existing rows retained their prior (true) value by the
  // migration (bestehende Daten unangetastet — nur der DEFAULT ändert
  // sich für zukünftige product.create calls ohne explizite Felder).
  channelFacebook Boolean @default(false) @map("channel_facebook")
  channelTiktok   Boolean @default(false) @map("channel_tiktok")
  channelGoogle   Boolean @default(false) @map("channel_google")
  channelWhatsapp Boolean @default(false) @map("channel_whatsapp")
  publishedAt DateTime? @map("published_at")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category       Category              @relation(fields: [categoryId], references: [id])
  translations   ProductTranslation[]
  variants       ProductVariant[]
  images         ProductImage[]
  reviews        ProductReview[]
  wishlistItems  WishlistItem[]
  channelListings ChannelProductListing[]
  coupons        Coupon[]
  promotions     Promotion[]

  @@map("products")
}

model ProductTranslation {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  language    Language
  name        String
  description String?
  sizeGuide   String?  @map("size_guide")
  metaTitle   String?  @map("meta_title")
  metaDesc    String?  @map("meta_desc")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, language])
  @@map("product_translations")
}

model ProductVariant {
  id                String    @id @default(uuid())
  productId         String    @map("product_id")
  shopifyVariantId  String?   @unique @map("shopify_variant_id")
  sku               String    @unique
  barcode           String?   @unique
  color             String?
  colorHex          String?   @map("color_hex")
  size              String?
  sizeSystem        SizeSystem? @map("size_system")
  priceModifier     Decimal   @default(0) @map("price_modifier") @db.Decimal(10, 2)
  purchasePrice     Decimal?  @map("purchase_price") @db.Decimal(10, 2)
  weightGrams       Int?      @map("weight_grams")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  product           Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory         Inventory[]
  orderItems        OrderItem[]
  channelListings   ChannelProductListing[]
  stockReservations StockReservation[]

  @@map("product_variants")
}

model ProductImage {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  url        String
  altText    String?  @map("alt_text")
  colorName  String?  @map("color_name")  // links image to a color variant
  sortOrder  Int      @default(0) @map("sort_order")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─────────────────────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────────────────────

model Warehouse {
  id        String        @id @default(uuid())
  name      String
  address   String?
  type      WarehouseType @default(WAREHOUSE)
  isActive  Boolean       @default(true) @map("is_active")
  isDefault Boolean       @default(false) @map("is_default")
  createdAt DateTime      @default(now()) @map("created_at")

  inventory          Inventory[]
  inventoryMovements InventoryMovement[]
  stockReservations  StockReservation[]
  locations          InventoryLocation[]
  fulfilledOrders    Order[]

  @@map("warehouses")
}

model Inventory {
  id                String   @id @default(uuid())
  variantId         String   @map("variant_id")
  warehouseId       String   @map("warehouse_id")
  locationId        String?  @map("location_id")
  quantityOnHand    Int      @default(0) @map("quantity_on_hand")
  quantityReserved  Int      @default(0) @map("quantity_reserved")
  reorderPoint      Int      @default(5) @map("reorder_point")
  maxStock          Int      @default(100) @map("max_stock")
  reorderQuantity   Int      @default(20) @map("reorder_quantity")
  lastSyncedAt      DateTime? @map("last_synced_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  variant   ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse         @relation(fields: [warehouseId], references: [id])
  location  InventoryLocation? @relation(fields: [locationId], references: [id])

  @@unique([variantId, warehouseId])
  @@map("inventory")
}

model InventoryMovement {
  id             String                @id @default(uuid())
  variantId      String                @map("variant_id")
  warehouseId    String                @map("warehouse_id")
  type           InventoryMovementType
  quantity       Int                   // positiv = eingang, negativ = ausgang
  quantityBefore Int?                  @map("quantity_before")
  quantityAfter  Int?                  @map("quantity_after")
  referenceId    String?               @map("reference_id") // orderId, reservationId, supplierDeliveryItemId, transferId etc.
  // Partial unique index for supplier_delivery idempotency is defined in
  // prisma/migrations/20260420_supplier_delivery_item_unique/migration.sql
  // (Prisma does not support partial unique indexes declaratively).
  // DO NOT add @@unique([referenceId, variantId]) here — it would incorrectly
  // apply to every movement type. See that migration file for full rationale.
  notes          String?
  createdBy      String?               @map("created_by")
  createdAt      DateTime              @default(now()) @map("created_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([variantId, warehouseId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model StockReservation {
  id          String            @id @default(uuid())
  variantId   String            @map("variant_id")
  warehouseId String            @map("warehouse_id")
  orderId     String?           @map("order_id")
  sessionId   String?           @map("session_id")
  quantity    Int
  status      ReservationStatus @default(RESERVED)
  expiresAt   DateTime          @map("expires_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])

  @@index([variantId, warehouseId, status])
  @@index([expiresAt, status])
  @@map("stock_reservations")
}

model LowStockAlert {
  id           String    @id @default(uuid())
  variantId    String    @map("variant_id")
  warehouseId  String    @map("warehouse_id")
  currentQty   Int       @map("current_qty")
  reorderPoint Int       @map("reorder_point")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([variantId, resolvedAt])
  @@map("low_stock_alerts")
}

model InventoryLocation {
  id          String   @id @default(uuid())
  warehouseId String   @map("warehouse_id")
  name        String   // "Regal A1", "Schaufenster", "Lager hinten"
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  warehouse  Warehouse   @relation(fields: [warehouseId], references: [id])
  inventory  Inventory[]

  @@index([warehouseId])
  @@map("inventory_locations")
}

model Stocktake {
  id          String    @id @default(uuid())
  status      String    @default("in_progress") // in_progress, completed, cancelled
  categoryId  String?   @map("category_id")
  warehouseId String    @map("warehouse_id")
  adminId     String    @map("admin_id")
  notes       String?
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  items StocktakeItem[]

  @@index([status])
  @@map("stocktakes")
}

model StocktakeItem {
  id           String @id @default(uuid())
  stocktakeId  String @map("stocktake_id")
  variantId    String @map("variant_id")
  expectedQty  Int    @map("expected_qty")
  actualQty    Int?   @map("actual_qty")
  difference   Int?

  stocktake Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)

  @@index([stocktakeId])
  @@map("stocktake_items")
}

// ─────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────

model Order {
  id                String       @id @default(uuid())
  orderNumber       String       @unique @map("order_number")
  shopifyOrderId    String?      @map("shopify_order_id")
  userId            String?      @map("user_id")
  guestEmail        String?      @map("guest_email")
  shippingAddressId       String?  @map("shipping_address_id")
  shippingAddressSnapshot Json?    @map("shipping_address_snapshot")
  status                  OrderStatus  @default(pending)
  channel           SalesChannel @default(website)
  channelOrderId    String?      @map("channel_order_id")
  channelFee        Decimal      @default(0) @map("channel_fee") @db.Decimal(10, 2)
  subtotal          Decimal      @map("subtotal") @db.Decimal(10, 2)
  shippingCost      Decimal      @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  taxAmount         Decimal      @map("tax_amount") @db.Decimal(10, 2)
  discountAmount    Decimal      @default(0) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount       Decimal      @map("total_amount") @db.Decimal(10, 2)
  currency          String       @default("EUR")
  shippingZone      String?      @map("shipping_zone")
  couponCode        String?      @map("coupon_code")
  promotionId       String?      @map("promotion_id")
  notes                  String?
  fulfillmentWarehouseId String?  @map("fulfillment_warehouse_id")
  cancelledAt            DateTime?    @map("cancelled_at")
  cancelReason           String?      @map("cancel_reason")
  refundStatus           String?      @map("refund_status")    // succeeded | failed | pending | not_needed
  refundError            String?      @map("refund_error")
  // Admin read-tracking — powers the sidebar "unread orders" badge and the
  // unread marker on the orders list. Set exactly once on the first admin
  // detail-view; never cleared after. Independent from order.status so a
  // shipped order that was never opened by an admin still counts as unread.
  firstViewedByAdminAt   DateTime?    @map("first_viewed_by_admin_at")
  firstViewedByAdmin     String?      @map("first_viewed_by_admin")
  deletedAt              DateTime?    @map("deleted_at")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  user                 User?                @relation(fields: [userId], references: [id])
  shippingAddress      Address?             @relation(fields: [shippingAddressId], references: [id])
  fulfillmentWarehouse Warehouse?           @relation(fields: [fulfillmentWarehouseId], references: [id])
  items           OrderItem[]
  payment         Payment?
  shipment        Shipment?
  returns         Return[]
  couponUsages    CouponUsage[]
  statusHistory   OrderStatusHistory[]
  invoices        Invoice[]

  @@index([userId, status])
  @@index([createdAt, id])
