model Return {
  id                    String       @id @default(uuid())
  returnNumber          String?      @unique @map("return_number")
  orderId               String       @map("order_id")
  shipmentId            String?      @map("shipment_id")
  reason                ReturnReason
  status                ReturnStatus @default(requested)
  notes                 String?
  adminNotes            String?      @map("admin_notes")
  rejectionReason       String?      @map("rejection_reason")
  returnItems           Json?        @map("return_items") // [{itemId, sku, name, quantity, unitPrice, condition}]
  customerPhotos        Json?        @map("customer_photos") // [url1, url2]
  returnLabelUrl        String?      @map("return_label_url")
  returnTrackingNumber  String?      @map("return_tracking_number")
  deadline              DateTime?    // delivery_date + 14 days
  approvedAt            DateTime?    @map("approved_at")
  approvedBy            String?      @map("approved_by")
  receivedAt            DateTime?    @map("received_at")
  inspectedAt           DateTime?    @map("inspected_at")
