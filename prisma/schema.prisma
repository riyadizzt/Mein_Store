  bodyType      String?   @map("body_type")          // slim, regular, athletic, plus
  bustCm        Decimal?  @map("bust_cm") @db.Decimal(5, 1)
  waistCm       Decimal?  @map("waist_cm") @db.Decimal(5, 1)
  hipCm         Decimal?  @map("hip_cm") @db.Decimal(5, 1)
  footLengthCm  Decimal?  @map("foot_length_cm") @db.Decimal(5, 1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_measurements")
}

