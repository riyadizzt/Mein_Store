// ─────────────────────────────────────────────────────────────
// Webhook outbound integration (n8n, Zapier, custom endpoints)
// Plugin-artig: keine FK zu anderen Tabellen, reine String-Referenzen.
// Entfernbar ohne Systemauswirkungen.
// ─────────────────────────────────────────────────────────────

model WebhookSubscription {
  id                  String    @id @default(uuid())
  url                 String
  secret              String    // shared secret for HMAC-SHA256 signature
  events              String[]  // event type whitelist, e.g. ['order.created', 'return.requested']
  isActive            Boolean   @default(true) @map("is_active")
  description         String?   // admin-friendly label

  // Delivery statistics (updated on each delivery attempt)
  totalDeliveries     Int       @default(0) @map("total_deliveries")
  totalSuccesses      Int       @default(0) @map("total_successes")
  totalFailures       Int       @default(0) @map("total_failures")
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  lastDeliveryAt      DateTime? @map("last_delivery_at")
  lastSuccessAt       DateTime? @map("last_success_at")
  lastFailureAt       DateTime? @map("last_failure_at")

  createdBy           String?   @map("created_by") // User.id — no FK
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("webhook_subscriptions")
}

model WebhookDeliveryLog {
  id             String    @id @default(uuid())
  subscriptionId String    @map("subscription_id") // WebhookSubscription.id — no FK
  eventType      String    @map("event_type") // e.g. 'order.created'
  eventId        String    @map("event_id") // uuid — X-Malak-Event-Id header, idempotency key
  payload        Json      // full Stripe-style payload sent to n8n

  // Result
  status         String    @default("pending") // pending | success | failed
  httpStatus     Int?      @map("http_status")
  responseBody   String?   @map("response_body") @db.Text
  errorMessage   String?   @map("error_message") @db.Text
  attemptCount   Int       @default(0) @map("attempt_count")

  // Timing
  nextAttemptAt  DateTime? @map("next_attempt_at")
  lastAttemptAt  DateTime? @map("last_attempt_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([subscriptionId, eventId]) // prevent double-enqueue of same event to same sub
  @@index([subscriptionId])
  @@index([status])
  @@index([eventType])
  @@index([createdAt])
  @@map("webhook_delivery_logs")
}

// ═══════════════════════════════════════════════════════════════════
// BACKUP SYSTEM (Pre-Launch Basic Level)
// ═══════════════════════════════════════════════════════════════════
//
// Every backup attempt — successful or failed — gets a row. Retention
// policy (30 daily + 12 monthly + 14-day manual) keeps the DB row
// around even after the R2 object is deleted so the audit trail stays
// intact. status=EXPIRED marks rows whose R2 object has been pruned.

model BackupLog {
  id                  String         @id @default(uuid())
  type                BackupType     // DAILY | MONTHLY | MANUAL
  status              BackupStatus   // RUNNING | SUCCESS | FAILED | EXPIRED

  startedAt           DateTime       @default(now()) @map("started_at")
  completedAt         DateTime?      @map("completed_at")

  // Populated on SUCCESS only
  sizeBytes           BigInt?        @map("size_bytes")
  storageKey          String?        @map("storage_key")  // R2 object key, e.g. "daily/2026-04-22T03-00-00Z.sql.gz"
  sha256              String?        // hex digest of the uploaded blob

  // Populated on FAILED only
  errorMessage        String?        @map("error_message") @db.Text

  // Null for cron-triggered backups, set for /admin/backups/manual
  triggeredByUserId   String?        @map("triggered_by_user_id")

  createdAt           DateTime       @default(now()) @map("created_at")

  @@index([type, status, startedAt(sort: Desc)])
  @@index([status])
  @@map("backup_log")
}

enum BackupType {
  DAILY
  MONTHLY
  MANUAL
}

enum BackupStatus {
  RUNNING
  SUCCESS
  FAILED
  EXPIRED // R2 object pruned by retention, DB row kept for audit
}

// ─────────────────────────────────────────────────────────────
// MARKETPLACE — Phase 2 (eBay) / Phase 3 (TikTok Shop)
// ─────────────────────────────────────────────────────────────
//
// Sidecar pattern: Marketplace-specific metadata lives next to the
// OrdersService output, not inside `orders`. Keeps the core Order
// model untouched (see Phase-2 Arbeitsregel: "Null Touch an Orders").
//
// Lifecycle row per external-order import attempt. Serves THREE
// purposes:
//
//   1. Idempotency-Gate: @@unique([marketplace, externalOrderId])
//      raises P2002 on duplicate webhook + pull-cron race, so only
//      one importer path succeeds in creating the local Order.
//
//   2. Failure-Audit: import can fail at preflight (no stock,
//      address invalid, price mismatch) without any local Order
//      existing yet. We still need a trace of "eBay order X was
//      attempted, rejected because Y".
//
//   3. Metadata-Sidecar: eBay-specific fields (buyerUsername,
//      eBay-item-IDs per line, eBay-return-policy-snapshot, etc.)
//      live in `metadata` JSON. Order.channelOrderId holds the
//      external ID as top-level indexable column; the rest stays
//      here to keep `orders` schema stable.
//
// Status lifecycle:
//   IMPORTING → IMPORTED (Order created + payment captured)
//             → FAILED   (hard error before Order exists)
//             → SKIPPED  (dedup hit — duplicate event for existing Order)

model MarketplaceOrderImport {
  id              String                     @id @default(uuid())
  marketplace     Marketplace
  externalOrderId String                     @map("external_order_id")
  status          MarketplaceImportStatus    @default(IMPORTING)

  // Linked local Order — populated once status transitions to IMPORTED.
  // NOT a foreign-key on purpose: local Order may be soft-deleted or
  // rebuilt after disaster recovery; keeping this loose preserves the
  // audit trail. String-only reference.
  orderId         String?                    @map("order_id")

  // Arbitrary marketplace-specific payload. Shape documented per
  // marketplace in the adapter module. Never read by the Orders/
  // Invoice/Payment services — only by the marketplace adapter.
  metadata        Json?

  // On FAILED: short human-readable reason (max 500 chars enforced
  // at service level). Full stack-trace goes to Sentry instead.
  error           String?                    @db.Text

  // Correlation to notification-api payload for replay/debug.
  rawEventId      String?                    @map("raw_event_id")

  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt      @map("updated_at")
  importedAt      DateTime?                  @map("imported_at")

  @@unique([marketplace, externalOrderId], name: "marketplace_external_order_unique")
  @@index([marketplace, status, createdAt])
  @@index([orderId])
  @@map("marketplace_order_imports")
}

enum Marketplace {
  EBAY
  TIKTOK
}

enum MarketplaceImportStatus {
  IMPORTING // row claimed by an importer, Order not yet created
  IMPORTED  // local Order row exists, payment captured, invoice flow kicked off
  FAILED    // hard error before Order creation — see `error` field
  SKIPPED   // duplicate event, local Order already exists (dedup hit)
}
