model Shipment {
  id                  String          @id @default(uuid())
  orderId             String          @unique @map("order_id")
  carrier             ShipmentCarrier
  status              ShipmentStatus  @default(pending)
  providerShipmentId  String?         @map("provider_shipment_id")
  trackingNumber      String?         @map("tracking_number")
  trackingUrl         String?         @map("tracking_url")
  labelUrl            String?         @map("label_url")
  returnLabelUrl      String?         @map("return_label_url")
  shippedAt           DateTime?       @map("shipped_at")
  deliveredAt         DateTime?       @map("delivered_at")
  estimatedDelivery   DateTime?       @map("estimated_delivery")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  returns Return[]

  @@index([trackingNumber])
  @@map("shipments")
}

model Return {
  id                    String       @id @default(uuid())
  returnNumber          String?      @unique @map("return_number")
  orderId               String       @map("order_id")
  shipmentId            String?      @map("shipment_id")
  reason                ReturnReason
  status                ReturnStatus @default(requested)
  notes                 String?
  adminNotes            String?      @map("admin_notes")
  rejectionReason       String?      @map("rejection_reason")
  returnItems           Json?        @map("return_items") // [{itemId, sku, name, quantity, unitPrice, condition}]
  customerPhotos        Json?        @map("customer_photos") // [url1, url2]
  returnLabelUrl        String?      @map("return_label_url")
  returnTrackingNumber  String?      @map("return_tracking_number")
  deadline              DateTime?    // delivery_date + 14 days
  approvedAt            DateTime?    @map("approved_at")
  approvedBy            String?      @map("approved_by")
  receivedAt            DateTime?    @map("received_at")
  inspectedAt           DateTime?    @map("inspected_at")
  inspectedBy           String?      @map("inspected_by")
  refundedAt            DateTime?    @map("refunded_at")
  refundAmount          Decimal?     @map("refund_amount") @db.Decimal(10, 2)
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  order    Order     @relation(fields: [orderId], references: [id])
  shipment Shipment? @relation(fields: [shipmentId], references: [id])

  @@index([orderId])
  @@index([returnNumber])
  @@map("returns")
}

model ReturnSequence {
  yearKey String @id @map("year_key") // RET-2026
  seq     Int    @default(1)

  @@map("return_sequences")
}

