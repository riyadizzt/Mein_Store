  previousProviderPaymentIds String[]  @default([]) @map("previous_provider_payment_ids")
  providerClientSecret String?         @map("provider_client_secret")
  idempotencyKey       String?         @unique @map("idempotency_key")
  failureReason        String?         @map("failure_reason")
