# Dependencies
node_modules
.pnp
.pnp.js

# Build outputs
dist/
.next/
.expo/
out/

# Environment files — NIEMALS committen! (Secrets inside)
# Blanket rule catches every variant in every subfolder.
.env
.env.*
!.env.example
!.env.*.example
# Explicit belt-and-suspenders for historical names
.env.local
.env.staging
.env.production
.env.production.template
apps/*/.env
apps/*/.env.*
!apps/*/.env.example

# Turbo
.turbo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Prisma
prisma/migrations/

# Testing
coverage/
.nyc_output

# Vercel
.vercel

# Sentry
.sentryclirc

# Shipping labels (generated PDFs) — local artifacts, keep everywhere
storage/labels/
apps/api/storage/labels/

# TypeScript incremental build cache
*.tsbuildinfo

# Separate standalone shop repo — not part of omnichannel-store
Mein_Store/

# Dead / WIP source files — git IS the backup mechanism, these
# shapes do not belong in the compiled source tree. tsconfig also
# excludes them from compilation (apps/api/tsconfig.json).
# Historic case: orders.service.backup.ts (07.04.2026) silently
# survived a prisma schema drift and broke Railway's fresh-build.
*.backup.ts
*.backup.tsx
*.old.ts
*.old.tsx
*.bak.ts
*.bak.tsx
*.draft.ts
*.draft.tsx
